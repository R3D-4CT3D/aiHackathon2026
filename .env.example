# Copy this file to .env and fill in your API keys.
# The app works without any keys using a smart mock analysis engine.
# Add keys progressively — each one enables an additional enrichment layer.

# Optional — enables GPT-4o-mini reasoning layer
OPENAI_API_KEY=sk-replace_me

# Optional — enables VirusTotal engine-vote URL scanning
VIRUSTOTAL_API_KEY=replace_me

# Optional — enables Google Safe Browsing real-time threat classification
GOOGLE_SAFE_BROWSING_API_KEY=replace_me

# Optional — enables URLScan.io passive scan lookup
URLSCAN_API_KEY=replace_me
